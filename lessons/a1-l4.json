      "intro": "Usamos <b style='color:var(--gold)'>have</b> para posesiones y familia. Estudia con las tarjetas y practica.",
      "cells": [
        {
          "h": "✓ have / has",
          "body": "I / you / we / they <code>have</code><br>he / she / it <code>has</code><br>I have a dog."
        },
        {
          "h": "✗ Negative · ? Question",
          "body": "I <code>don't have</code> a car.<br>She <code>doesn't have</code> a pet.<br><code>Do you have</code> a pet?"
        },
        {
          "h": "👪 Possessives",
          "body": "<code>my</code> · <code>your</code> · <code>his</code> · <code>her</code><br>This is <code>my</code> sister.<br><code>Her</code> name is Lucy."
        },
        {
          "h": "⚠ Watch out",
          "body": "<span class='x'>She have</span> → <span class='ok'>She has</span><br><span class='x'>his sister name</span> → <span class='ok'>his sister's name</span>"
        }
